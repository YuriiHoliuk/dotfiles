alias c='clear'

alias ls="eza -F"
alias ll="eza -alhF"
alias tree="eza --tree"

alias ..='cd ../'
alias ...='cd ../../'
alias ....='cd ../../../'

alias mkdir='mkdir -pv'

alias h='history'

alias find='fd'
alias cat='bat'

# Claude Code
alias opus='claude --dangerously-skip-permissions --model "claude-opus-4-7[1m]"'
alias sonnet='claude --dangerously-skip-permissions --model sonnet'
alias haiku='claude --dangerously-skip-permissions --model haiku'

# Git aliases
alias gs='git status'
alias gd='git diff'
alias glog='git log --pretty=format:"%C(green)%h  %C(yellow)%ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short'
alias gb='git branch'
alias gcb='git checkout `git branch | fzf`'

alias go='git checkout'
alias gob='git checkout -b'
alias ga='git add'
alias gaa='git add -A'
alias gc='git commit'
alias gcm='git commit -m'
alias gca='gaa && gcm'

alias gps='git push'
alias gpsf='git push --force'
alias gpsn='git push --set-upstream origin $(git rev-parse --abbrev-ref HEAD)'
alias gpl='git pull --rebase'

alias grm='git fetch origin && git rebase origin/master'

alias git-delete-all='git branch | grep -v "master" | grep -v "develop" | grep -v ^* | xargs git branch -D'
alias fresh='go master && gpl && gob'

# Navigate to git root or home
zz() {
    local git_root=$(git rev-parse --show-toplevel 2>/dev/null)

    if [[ -n "$git_root" ]]; then
        if [[ "$PWD" != "$git_root" ]]; then
            cd "$git_root"
        fi
    else
        cd ~
    fi
}

# ZSH
alias zrc="nvim ~/dotfiles/home-files-jetson/.zshrc"
alias zsrc="source ~/.zshrc"
alias zal="nvim ~/dotfiles/home-files-jetson/.zsh_aliases"

# Vim
alias vi="nvim"
alias vim="nvim"
alias vv="nvim ."

# Dotfiles
alias stw="stow --dir=$HOME/dotfiles --target=$HOME home-files home-files-jetson"

# Docker
alias d='docker'
alias dc='docker compose'
alias dps='docker ps'
alias dlog='docker logs -f'
