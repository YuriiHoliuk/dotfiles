{
    "description": "cmux: Alt+E/Alt+Shift+E → Open Cursor in pane directory, Alt+Shift+H/L → workspace nav",
    "manipulators": [
        {
            "type": "basic",
            "from": {
                "key_code": "e",
                "modifiers": { "mandatory": ["option"] }
            },
            "to": [{ "shell_command": "~/.local/bin/cmux-open-cursor.sh" }],
            "conditions": [{ "type": "frontmost_application_if", "bundle_identifiers": ["com.cmuxterm.app"] }]
        },
        {
            "type": "basic",
            "from": {
                "key_code": "e",
                "modifiers": { "mandatory": ["option", "shift"] }
            },
            "to": [{ "shell_command": "~/.local/bin/cmux-open-cursor.sh" }],
            "conditions": [{ "type": "frontmost_application_if", "bundle_identifiers": ["com.cmuxterm.app"] }]
        },
        {
            "type": "basic",
            "description": "Alt+Shift+H → previous workspace",
            "from": {
                "key_code": "h",
                "modifiers": { "mandatory": ["option", "shift"] }
            },
            "to": [{ "key_code": "open_bracket", "modifiers": ["command", "control"] }],
            "conditions": [{ "type": "frontmost_application_if", "bundle_identifiers": ["com.cmuxterm.app"] }]
        },
        {
            "type": "basic",
            "description": "Alt+Shift+L → next workspace",
            "from": {
                "key_code": "l",
                "modifiers": { "mandatory": ["option", "shift"] }
            },
            "to": [{ "key_code": "close_bracket", "modifiers": ["command", "control"] }],
            "conditions": [{ "type": "frontmost_application_if", "bundle_identifiers": ["com.cmuxterm.app"] }]
        },
        {
            "type": "basic",
            "description": "Alt+Shift+, → previous workspace",
            "from": {
                "key_code": "comma",
                "modifiers": { "mandatory": ["option", "shift"] }
            },
            "to": [{ "key_code": "open_bracket", "modifiers": ["command", "control"] }],
            "conditions": [{ "type": "frontmost_application_if", "bundle_identifiers": ["com.cmuxterm.app"] }]
        },
        {
            "type": "basic",
            "description": "Alt+Shift+. → next workspace",
            "from": {
                "key_code": "period",
                "modifiers": { "mandatory": ["option", "shift"] }
            },
            "to": [{ "key_code": "close_bracket", "modifiers": ["command", "control"] }],
            "conditions": [{ "type": "frontmost_application_if", "bundle_identifiers": ["com.cmuxterm.app"] }]
        }
    ]
}
